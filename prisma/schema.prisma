generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = "postgresql://neondb_owner:npg_2eWGNaKP8LZi@ep-crimson-tooth-a1xgngig-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

model peserta {
  id           Int       @id @default(autoincrement())
  nama         String
  whatsapp     String?
  email        String?   @unique
  usia         Int?
  alamat       String?
  pekerjaan    String?
  jumlah_pohon Int?
  timestamp    DateTime? @default(now()) @db.Timestamptz(6)
  motivasi     String?
  komentar     String?

  @@map("peserta")
}

model Komentar {
  id        Int      @id @default(autoincrement())
  nama      String?
  whatsapp  String?
  isi       String
  suka      Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([nama, whatsapp])
}
